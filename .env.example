# Copy to .env and fill in values (never commit .env)
# Used for local reference — production uses platform env vars

# ── PostgreSQL (Neon / Supabase) ──
# Neon example:
# ConnectionStrings__DefaultConnection=Host=ep-xxx.region.aws.neon.tech;Port=5432;Database=raas_db;Username=xxx;Password=xxx;SSL Mode=Require;Trust Server Certificate=true
# Supabase example:
# ConnectionStrings__DefaultConnection=Host=db.xxx.supabase.co;Port=5432;Database=postgres;Username=postgres;Password=xxx;SSL Mode=Require;Trust Server Certificate=true

ConnectionStrings__DefaultConnection=

# ── JWT (min 32 characters) ──
Jwt__Key=
Jwt__Issuer=RAAS
Jwt__Audience=RAAS

# ── Resend Email ──
Resend__ApiKey=re_xxxxxxxx
Resend__FromEmail=RAAS <orders@yourdomain.com>
Resend__AdminEmail=admin@yourdomain.com
Resend__Enabled=true

# ── CORS (your Vercel URL) ──
Frontend__Url=https://your-app.vercel.app
Frontend__AllowedOrigins__0=https://your-app.vercel.app
Frontend__AllowedOrigins__1=http://localhost:4200

# ── Optional ──
EnableSwagger=false
ASPNETCORE_ENVIRONMENT=Production
